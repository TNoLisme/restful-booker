#!/bin/sh
set -eu

zero_sha=0000000000000000000000000000000000000000
should_run=0

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    changed_files=$(git diff-tree --no-commit-id --name-only -r "$local_sha")
  else
    changed_files=$(git diff --name-only "$remote_sha" "$local_sha")
  fi

  if echo "$changed_files" | grep -q '^app-code/'; then
    should_run=1
  fi
done

if [ "$should_run" -eq 0 ]; then
  echo "No app-code changes detected; skipping API gate."
  exit 0
fi

echo "app-code changes detected; running API gate before push."

server_pid=""
if ! curl -fsS http://localhost:3001/ping >/dev/null 2>&1; then
  echo "Starting local Restful-Booker backend on port 3001."
  (cd app-code && npm install && npm start) &
  server_pid=$!

  i=0
  until curl -fsS http://localhost:3001/ping >/dev/null 2>&1
  do
    i=$((i + 1))
    if [ "$i" -gt 30 ]; then
      echo "Backend did not become ready on http://localhost:3001."
      [ -n "$server_pid" ] && kill "$server_pid" >/dev/null 2>&1 || true
      exit 1
    fi
    sleep 2
  done
fi

if command -v mvn.cmd >/dev/null 2>&1; then
  maven_cmd=mvn.cmd
else
  maven_cmd=mvn
fi

(cd karate-automation/karate/my_project && "$maven_cmd" clean test -Dtest=ApiTest)
result=$?

if [ -n "$server_pid" ]; then
  kill "$server_pid" >/dev/null 2>&1 || true
fi

exit "$result"
